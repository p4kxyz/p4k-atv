<?xml version="1.0" encoding="utf-8"?>
<com.files.codes.view.CustomFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:id="@+id/custom_frame_layout">

    <FrameLayout
        android:id="@+id/header_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="top|start"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/rows_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top|start"
        android:layout_marginStart="0dp" />

    <androidx.leanback.widget.SearchOrbView
        android:id="@+id/custom_search_orb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27dp"
        android:layout_marginStart="56dp"
        android:layout_gravity="top|start"/>

    <!-- Settings Orb (Top Right) -->
    <ImageView
        android:id="@+id/settings_orb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="27dp"
        android:layout_marginEnd="56dp"
        android:layout_gravity="top|end"
        android:elevation="20dp"
        android:src="@drawable/ic_settings_white"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:focusable="true"/>

</com.files.codes.view.CustomFrameLayout>