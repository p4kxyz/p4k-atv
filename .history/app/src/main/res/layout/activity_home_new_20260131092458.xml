<?xml version="1.0" encoding="utf-8"?>
<com.files.codes.view.CustomFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:id="@+id/custom_frame_layout">

    <!-- Fragment Container (Behind Hero Banner, scrollable) -->
    <FrameLayout
        android:id="@+id/rows_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top|start">
        
        <fragment
            android:id="@+id/page_list_fragment"
            android:name="com.files.codes.view.fragments.testFolder.HomeNewFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
            
    </FrameLayout>

    <!-- Search Orb (Above everything, elevation=20dp) -->
    <androidx.leanback.widget.SearchOrbView
        android:id="@+id/custom_search_orb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27dp"
        android:layout_marginStart="56dp"
        android:layout_gravity="top|start"
        android:elevation="20dp"
        android:visibility="gone"/>

    <!-- Settings Orb (Top Right, elevation=100dp) -->
    <ImageView
        android:id="@+id/settings_orb"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="40dp"
        android:padding="10dp"
        android:layout_gravity="top|end"
        android:visibility="visible"
        android:elevation="100dp"
        android:src="@drawable/ic_settings_white"
        android:scaleType="fitCenter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:focusable="true"
        android:clickable="true"/>

    <!-- Sidebar Menu (Above everything, elevation=30dp) -->
    <FrameLayout
        android:id="@+id/header_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="top|start"
        android:visibility="gone"
        android:elevation="30dp" />

</com.files.codes.view.CustomFrameLayout>