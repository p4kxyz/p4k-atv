<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="60dp"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/episode_list_background"
    android:focusable="true"
    android:layout_marginBottom="4dp">

    <!-- Episode Thumbnail -->
    <ImageView
        android:id="@+id/episode_thumbnail"
        android:layout_width="80dp"
        android:layout_height="45dp"
        android:scaleType="centerCrop"
        android:background="@drawable/episode_thumbnail_background"
        android:layout_marginEnd="12dp"
        tools:src="@drawable/placeholder" />

    <!-- Episode Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/episode_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            tools:text="Tập 1: Khởi đầu" />

        <TextView
            android:id="@+id/episode_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="Mô tả tập phim..." />

    </LinearLayout>

    <!-- Episode Duration -->
    <TextView
        android:id="@+id/episode_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:visibility="gone"
        tools:text="42 phút" />

</LinearLayout>