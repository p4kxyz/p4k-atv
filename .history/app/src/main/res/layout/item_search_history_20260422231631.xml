<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chip_container"
    android:layout_width="wrap_content"
    android:layout_height="52dp"
    android:layout_marginStart="10dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/search_history_chip_bg"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minWidth="220dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/iv_history_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="10dp"
        android:alpha="0.9"
        android:src="@android:drawable/ic_menu_search"
        android:tint="#DADADA" />

    <TextView
        android:id="@+id/tv_history_query"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#F3F3F3"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btn_history_delete"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/search_history_delete_bg"
        android:contentDescription="Xoa"
        android:focusable="false"
        android:clickable="false"
        android:padding="5dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#FFE0E0" />

</LinearLayout>