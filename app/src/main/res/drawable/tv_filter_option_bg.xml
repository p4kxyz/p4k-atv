<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused + Selected (active filter) -->
    <item android:state_focused="true" android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#1565C0"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#64B5F6"/>
        </shape>
    </item>
    <!-- Focused -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#424242"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#42A5F5"/>
        </shape>
    </item>
    <!-- Selected (active filter, not focused) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#1B5E20"/>
            <corners android:radius="8dp"/>
            <stroke android:width="2dp" android:color="#66BB6A"/>
        </shape>
    </item>
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2a2a2a"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
