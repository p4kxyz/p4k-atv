<?xml version="1.0" encoding="utf-8"?>
<!-- Single filter option item - TV optimized with large touch target -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/tv_filter_option_bg"
    android:padding="14dp"
    android:minHeight="52dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:descendantFocusability="blocksDescendants">

    <!-- Check icon (shown for selected item) -->
    <TextView
        android:id="@+id/tv_filter_check"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="✓"
        android:textSize="18sp"
        android:textColor="#66BB6A"
        android:gravity="center"
        android:visibility="invisible"/>

    <!-- Option text -->
    <TextView
        android:id="@+id/tv_filter_option_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Option Name"
        android:textSize="18sp"
        android:textColor="#EEEEEE"
        android:paddingStart="10dp"
        android:maxLines="2"
        android:ellipsize="end"/>
</LinearLayout>
