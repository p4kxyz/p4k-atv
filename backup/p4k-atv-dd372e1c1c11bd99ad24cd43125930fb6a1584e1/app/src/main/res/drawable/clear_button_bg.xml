<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#EF5350"
                android:centerColor="#F44336"
                android:endColor="#D32F2F"
                android:type="linear"/>
            <corners android:radius="15dp"/>
            <stroke android:width="3dp" android:color="#E57373"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#E64A19"
                android:centerColor="#D84315"
                android:endColor="#BF360C"
                android:type="linear"/>
            <corners android:radius="15dp"/>
            <stroke android:width="2dp" android:color="#FF5722"/>
        </shape>
    </item>
</selector>


