<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#42A5F5"
                android:centerColor="#2196F3"
                android:endColor="#1976D2"
                android:type="linear"/>
            <corners android:radius="15dp"/>
            <stroke android:width="3dp" android:color="#64B5F6"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#424242"
                android:centerColor="#333333"
                android:endColor="#2a2a2a"
                android:type="linear"/>
            <corners android:radius="15dp"/>
            <stroke android:width="2dp" android:color="#555555"/>
        </shape>
    </item>
</selector>


