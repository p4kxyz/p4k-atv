<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state - white border with dark outline for contrast -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Outer dark border for contrast against white images -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="4dp"
                        android:color="#DD000000" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <!-- Inner white border -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="2dp"
                        android:color="#FFFFFF" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Default state - transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
</selector>
