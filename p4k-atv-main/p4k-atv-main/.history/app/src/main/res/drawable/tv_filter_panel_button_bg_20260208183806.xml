<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#1565C0"
                android:endColor="#0D47A1"
                android:type="linear"/>
            <corners android:radius="10dp"/>
            <stroke android:width="2dp" android:color="#64B5F6"/>
        </shape>
    </item>
    <!-- Has active filter (pressed look) -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#1B5E20"/>
            <corners android:radius="10dp"/>
            <stroke android:width="2dp" android:color="#66BB6A"/>
        </shape>
    </item>
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#3a3a3a"
                android:endColor="#2a2a2a"
                android:type="linear"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#555555"/>
        </shape>
    </item>
</selector>
