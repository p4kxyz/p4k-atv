<?xml version="1.0" encoding="utf-8"?>
<!-- TV-optimized filter selection dialog -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/filter_dialog_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <LinearLayout
        android:id="@+id/filter_dialog_panel"
        android:layout_width="420dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#DD1a1a1a"
        android:padding="20dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="false">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_filter_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chọn Thể Loại"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingBottom="16dp"
            android:drawablePadding="12dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#42A5F5"
            android:layout_marginBottom="12dp"/>

        <!-- Options list -->
        <ListView
            android:id="@+id/lv_filter_options"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:scrollbars="none"
            android:fadingEdge="vertical"
            android:fadingEdgeLength="40dp"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬆⬇ Chọn  •  ← Quay lại"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingTop="12dp"/>

    </LinearLayout>
</FrameLayout>
