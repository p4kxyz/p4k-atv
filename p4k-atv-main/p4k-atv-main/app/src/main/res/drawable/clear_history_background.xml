<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Dark gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#1A1A1A"
                android:centerColor="#2D2D2D"
                android:endColor="#404040"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Center focus area with red glow -->
    <item android:top="60dp" android:bottom="60dp" android:left="40dp" android:right="40dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#66FF5722"
                android:centerColor="#88F44336"
                android:endColor="#AAD32F2F"
                android:type="radial"
                android:gradientRadius="80dp" />
        </shape>
    </item>
    
    <!-- Top accent line -->
    <item android:top="20dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:height="2dp" />
        </shape>
    </item>
    
    <!-- Bottom accent line -->
    <item android:bottom="20dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:height="2dp" />
        </shape>
    </item>
    
    <!-- Left accent line -->
    <item android:left="20dp" android:top="40dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="2dp" />
        </shape>
    </item>
    
    <!-- Right accent line -->
    <item android:right="20dp" android:top="40dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="2dp" />
        </shape>
    </item>
    
</layer-list>