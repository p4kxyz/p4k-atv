<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#37474F"
                android:centerColor="#455A64"
                android:endColor="#546E7A"
                android:type="linear" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="#78909C" />
        </shape>
    </item>
    
    <!-- Center circle for icon -->
    <item android:top="25dp" android:bottom="25dp" android:left="25dp" android:right="25dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#FF5252"
                android:centerColor="#F44336"
                android:endColor="#D32F2F"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Inner border for circle -->
    <item android:top="28dp" android:bottom="28dp" android:left="28dp" android:right="28dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#FFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    
</layer-list>