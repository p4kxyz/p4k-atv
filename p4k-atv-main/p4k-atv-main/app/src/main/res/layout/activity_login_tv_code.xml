<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="40dp">

    <!-- Left panel: branding / instructions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingEnd="40dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập bằng điện thoại"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Mở app Phim4K trên điện thoại\n2. Vào Tài khoản → Đăng nhập trên TV\n3. Quét mã QR hoặc nhập mã hiển thị bên phải"
            android:textColor="#BBBBBB"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="220dp"
        android:background="#333333" />

    <!-- Right panel: code display -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã đăng nhập TV"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- QR Code -->
        <ImageView
            android:id="@+id/iv_qr_code"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"
            android:contentDescription="QR Code" />

        <!-- The 6-digit code -->
        <TextView
            android:id="@+id/tv_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="------"
            android:textColor="#64B5F6"
            android:textSize="64sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- Countdown -->
        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hết hạn sau 5:00"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Status message -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang chờ xác nhận từ điện thoại..."
            android:textColor="#64B5F6"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="20dp" />

        <!-- Refresh button -->
        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Tạo mã mới"
            android:background="@drawable/button_focus"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
