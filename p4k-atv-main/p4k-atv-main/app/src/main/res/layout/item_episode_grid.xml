<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="140dp"
    android:layout_height="140dp"
    android:orientation="vertical"
    android:padding="4dp"
    android:background="@drawable/episode_item_background"
    android:focusable="true"
    android:clickable="true"
    android:gravity="center">

    <!-- Episode Square Background -->
    <RelativeLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/episode_square_background">

        <!-- Episode Thumbnail (if available) -->
        <ImageView
            android:id="@+id/episode_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#40000000"
            android:contentDescription="Episode Thumbnail"
            android:visibility="gone" />

        <!-- Episode Number/Name (Overlay on square) -->
        <TextView
            android:id="@+id/episode_name"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#80000000"
            android:maxLines="3"
            android:ellipsize="end"
            android:padding="8dp"
            tools:text="Tập 1" />

    </RelativeLayout>

</LinearLayout>