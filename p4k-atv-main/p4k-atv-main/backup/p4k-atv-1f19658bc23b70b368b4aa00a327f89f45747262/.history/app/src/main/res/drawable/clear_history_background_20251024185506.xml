<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Background base -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#1A1A1A"
                android:centerColor="#2D2D2D"
                android:endColor="#404040"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Grid pattern overlay -->
    <item>
        <bitmap
            android:gravity="fill"
            android:tileMode="repeat">
            <shape android:shape="rectangle">
                <stroke android:width="1dp" android:color="#33FFFFFF" />
                <size android:width="20dp" android:height="20dp" />
                <solid android:color="@android:color/transparent" />
            </shape>
        </bitmap>
    </item>
    
    <!-- Center focus area -->
    <item android:top="30%" android:bottom="30%" android:left="20%" android:right="20%">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#44FF5722"
                android:centerColor="#44F44336"
                android:endColor="#44D32F2F"
                android:type="radial"
                android:gradientRadius="100dp" />
        </shape>
    </item>
    
    <!-- Decorative corners -->
    <item android:top="10dp" android:left="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="3dp" android:height="20dp" />
        </shape>
    </item>
    
    <item android:top="10dp" android:left="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="20dp" android:height="3dp" />
        </shape>
    </item>
    
    <item android:top="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="3dp" android:height="20dp" />
        </shape>
    </item>
    
    <item android:top="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
            <size android:width="20dp" android:height="3dp" />
        </shape>
    </item>
    
</layer-list>