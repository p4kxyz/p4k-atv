<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#424242"
                android:centerColor="#616161"
                android:endColor="#757575"
                android:type="linear" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#9E9E9E" />
        </shape>
    </item>
    
    <!-- Trash Can Body -->
    <item android:top="35dp" android:bottom="25dp" android:left="45dp" android:right="45dp">
        <shape android:shape="rectangle">
            <solid android:color="#F44336" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    
    <!-- Trash Can Lid -->
    <item android:top="30dp" android:bottom="80dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#D32F2F" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    
    <!-- Trash Can Handle -->
    <item android:top="25dp" android:bottom="85dp" android:left="60dp" android:right="60dp">
        <shape android:shape="rectangle">
            <solid android:color="#B71C1C" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    
</layer-list>