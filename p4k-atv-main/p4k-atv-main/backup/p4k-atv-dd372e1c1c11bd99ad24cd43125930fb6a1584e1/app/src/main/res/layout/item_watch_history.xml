<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view"
    android:layout_width="200dp"
    android:layout_height="320dp"
    android:layout_margin="8dp"
    android:focusable="true"
    android:clickable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/card_background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Poster Image -->
        <ImageView
            android:id="@+id/img_poster"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            android:background="@color/placeholder_gray" />

        <!-- Progress Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/img_poster"
            android:background="@drawable/gradient_overlay"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_watched"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginBottom="4dp"
                android:progressTint="@color/colorPrimary"
                android:progressBackgroundTint="@color/progress_background" />

            <!-- Progress Text -->
            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45%"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <!-- Duration -->
            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:30 / 45:00"
                android:textSize="10sp"
                android:textColor="@color/white_70" />

        </LinearLayout>

        <!-- Remove Button -->
        <ImageView
            android:id="@+id/btn_remove"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="8dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/circle_button_background"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            app:tint="@color/white" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/img_poster"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="Movie Title"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>